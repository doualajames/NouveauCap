      provinceNoteFr: 'En ligne uniquement - GAB via réseau Scotiabank'
    },
    {
      id: 'simpli',
      name: 'Simpli Financial',
      nameFr: 'Simpli Financial',
      logo: '⭐',
      color: 'from-pink-500 to-pink-700',
