  name: string
  nameEn?: string
  type: 'WALK_IN' | 'CLSC' | 'PRIVATE' | 'HOSPITAL' | 'COMMUNITY'
  address: string
  addressEn?: string
  phone: string
  hours?: string
  hoursEn?: string
  postalCode: string
  city: string
  cityEn?: string
  lat?: number
  lng?: number
  services?: string[]
  servicesEn?: string[]
  website?: string
}

