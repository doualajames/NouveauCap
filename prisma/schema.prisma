// NouveauCap - SaaS Platform for New Immigrants to Canada
// Prisma Schema — PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// User model with authentication and profile
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  avatar        String?

  // Profile information
  immigrationStatus  String?
  province          String?
  postalCode        String?
  arrivalDate       DateTime?
  dateOfBirth       DateTime?
  professionalSector String?
  preferredLanguage String?   @default("fr")
  familyStatus      String?
  countryOfOrigin   String?

  // Permit expiry dates for temporary residents
  studyPermitExpiry    DateTime?
  workPermitExpiry     DateTime?
  passportExpiry       DateTime?
  visaExpiry           DateTime?

  // Role-based access control
  role              String    @default("USER") // USER, ADMIN, PARTNER, ADVISOR, EMPLOYER

  // Subscription
  subscriptionTier  String    @default("FREE") // FREE, ESSENTIEL, PREMIUM, FAMILLE
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?

  // Metadata
  onboardingCompleted Boolean @default(false)
  emailVerified     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  tasks             Task[]
  documents         Document[]
  forumPosts        ForumPost[]
  forumComments     ForumComment[]
  events            EventRegistration[]
  alerts            Alert[]
  jobApplications   JobApplication[]
  profile           Profile?
  onboarding        Onboarding?
  subscription      Subscription?
  supportTickets    SupportTicket[]

  @@index([email])
}

// Task/Checklist model
model Task {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  titleEn     String?
  description String?
  descriptionEn String?
  category    String   // IMMIGRATION, EMPLOYMENT, HOUSING, FINANCE, HEALTH, COMMUNITY
  priority    String   @default("MEDIUM")
  status      String   @default("PENDING")

  dueDate     DateTime?
  completedAt DateTime?

  order       Int      @default(0)
  isRequired  Boolean  @default(false)
  source      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// Document model for user uploads and templates
model Document {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  type        String
  content     String?
  aiOptimized Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Forum Post model
model ForumPost {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  title       String
  content     String
  category    String
  province    String?

  likes       Int      @default(0)
  views       Int      @default(0)
  isPinned    Boolean  @default(false)

  comments    ForumComment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([category])
}

// Forum Comment model
model ForumComment {
  id          String   @id @default(cuid())
  postId      String
  post        ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content     String
  likes       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
}

// Event model
model Event {
  id          String   @id @default(cuid())
  title       String
  titleEn     String?
  description String?
  descriptionEn String?
  type        String
  province    String?
  city        String?
  address     String?

  date        DateTime
  endDate     DateTime?
  isVirtual   Boolean  @default(false)
  virtualLink String?
  capacity    Int?
  price       Float    @default(0)

  registrations EventRegistration[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([province])
  @@index([date])
}

// Event Registration model
model EventRegistration {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  registeredAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// Alert model for deadline reminders and in-app notifications
model Alert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String
  title       String
  message     String
  dueDate     DateTime

  isRead      Boolean  @default(false)
  isEmailSent Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([dueDate])
}

// Job Application tracker
model JobApplication {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  company     String
  position    String
  status      String   @default("APPLIED")
  appliedDate DateTime?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// User Profile — Extended profile information
model Profile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  immigrationStatus   String?
  province            String?
  city                String?
  arrivalDate         DateTime?
  plannedArrivalDate  DateTime?
  alreadyInCanada     Boolean   @default(true)

  professionalSector  String?
  yearsOfExperience   Int?
  educationLevel      String?

  preferredLanguage   String    @default("fr")
  needsFrenchClasses  Boolean   @default(false)
  needsEnglishClasses Boolean   @default(false)

  familyStatus        String?
  numberOfChildren    Int?
  primaryGoal         String?

  onboardingCompleted Boolean   @default(false)
  profileCompletion   Int       @default(0)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Onboarding progress tracking
model Onboarding {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  immigrationStatus   String?
  province            String?
  city                String?
  arrivalDate         DateTime?
  plannedArrivalDate  DateTime?
  alreadyInCanada     Boolean   @default(true)

  professionalSector  String?
  yearsOfExperience   Int?
  educationLevel      String?

  preferredLanguage   String    @default("fr")
  needsFrenchClasses  Boolean   @default(false)
  needsEnglishClasses Boolean   @default(false)

  familyStatus        String?
  numberOfChildren    Int?
  primaryGoal         String?

  currentStep         Int       @default(1)
  completed           Boolean   @default(false)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// User Subscription
model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan            String    @default("FREE")
  status          String    @default("ACTIVE")

  startDate       DateTime?
  endDate         DateTime?

  alertsLimit     Int       @default(3)
  alertsUsed      Int       @default(0)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Support Tickets for Admin
model SupportTicket {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject         String
  message         String
  status          String    @default("OPEN")
  priority        String    @default("NORMAL")

  response        String?
  respondedAt     DateTime?
  respondedBy     String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// Bank offers / B2B Partners
model BankOffer {
  id              String   @id @default(cuid())
  bankName        String
  bankNameEn      String?
  accountType     String
  monthlyFee      Float    @default(0)
  firstYearFree   Boolean  @default(false)
  newcomerOffer   String?
  newcomerOfferEn String?
  features        String?  // JSON string of features
  link            String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Province-specific information
model ProvinceInfo {
  id              String   @id @default(cuid())
  provinceCode    String   @unique
  provinceName    String
  provinceNameEn  String

  healthInsurance  String?
  housingInfo      String?
  taxInfo          String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
