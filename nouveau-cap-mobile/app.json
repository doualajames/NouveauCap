{
  "expo": {
    "name": "NouveauCap",
    "slug": "nouveau-cap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B82F6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nouveaucap.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "CFBundleDisplayName": "NouveauCap",
        "CFBundleName": "NouveauCap"
      }
    },
    "android": {
      "package": "com.nouveaucap.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B82F6"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "nouveau-cap"
      }
    },
    "owner": "nouveaucap"
  }
}
