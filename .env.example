# Base de données
# Dev (SQLite) :
DATABASE_URL="file:./db/custom.db"
# Prod (PostgreSQL/Supabase) — utiliser prisma/schema.postgresql.prisma :
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
# DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth — OBLIGATOIRE, min 32 caractères (générer : openssl rand -base64 32)
JWT_SECRET=""

# Admins — emails séparés par des virgules
ADMIN_EMAILS=""

# Stripe (optionnel en dev — les fonctions paiement se désactivent si absent)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_FAMILY_PRICE_ID=""

# URL publique de l'app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ANTHROPIC_API_KEY=""   # cle API Claude — fournisseur IA recommande (sinon fallback Z.ai en dev)
