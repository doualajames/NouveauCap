# ============================================================
# NouveauCap — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement local
# Ajoutez ces variables dans Vercel > Settings > Environment Variables
# ============================================================

# ── Base de données (Supabase) ────────────────────────────────
# Récupérez ces URLs dans Supabase > Project Settings > Database > Connection string
# Connection pooler URL (pour l'app en production / serverless)
DATABASE_URL="postgresql://postgres.VOTRE_REF:VOTRE_MOT_DE_PASSE@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct URL (pour prisma migrate / db push uniquement)
DIRECT_DATABASE_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_REF.supabase.co:5432/postgres"

# ── Authentification JWT ──────────────────────────────────────
JWT_SECRET="changez-moi-par-un-secret-aleatoire-de-minimum-32-caracteres"

# ── Email (Resend) ────────────────────────────────────────────
# Créez un compte sur resend.com et ajoutez votre domaine
# Votre clé API commence par "re_"
EMAIL_API_KEY="VOTRE_CLE_API_RESEND"
EMAIL_FROM="NouveauCap <noreply@votredomaine.com>"

# ── SMS (Twilio) — optionnel ──────────────────────────────────
# Disponible dans Twilio Console > Account Info
TWILIO_ACCOUNT_SID="VOTRE_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="VOTRE_TWILIO_AUTH_TOKEN"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# ── Notifications Push (OneSignal) — optionnel ────────────────
ONESIGNAL_APP_ID="VOTRE_ONESIGNAL_APP_ID"
ONESIGNAL_API_KEY="VOTRE_ONESIGNAL_API_KEY"

# ── Notifications Push Web (VAPID) — optionnel ───────────────
# Générez avec: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="VOTRE_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="VOTRE_VAPID_PRIVATE_KEY"

# ── Tâches planifiées (Cron) ──────────────────────────────────
# Utilisé pour sécuriser l'endpoint /api/notifications/check-expiry
CRON_SECRET="changez-moi-par-un-secret-aleatoire"

# ── IA / Anthropic — optionnel ───────────────────────────────
# Disponible sur console.anthropic.com
ANTHROPIC_API_KEY="VOTRE_CLE_API_ANTHROPIC"

# ── Paiements (Stripe) — optionnel ───────────────────────────
# Disponible dans le Dashboard Stripe > Developers > API keys
STRIPE_SECRET_KEY="VOTRE_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="VOTRE_STRIPE_WEBHOOK_SECRET"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="VOTRE_STRIPE_PUBLISHABLE_KEY"

# ── URL de l'app ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://votre-projet.vercel.app"
